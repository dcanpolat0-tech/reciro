OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
RECEIPT_ANALYSIS_PORT=8787
PORT=8787

# Optional: use the same value on the server and in the app to reduce casual abuse.
ANALYSIS_CLIENT_TOKEN=change-this-long-random-token
EXPO_PUBLIC_ANALYSIS_CLIENT_TOKEN=change-this-long-random-token

# Optional rate limit for the public analysis endpoint.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Use your Windows local network IP here when testing on a real phone.
# Example: EXPO_PUBLIC_RECEIPT_ANALYSIS_URL=http://192.168.1.125:8787/analyze-receipt
EXPO_PUBLIC_RECEIPT_ANALYSIS_URL=http://YOUR_COMPUTER_IP:8787/analyze-receipt
